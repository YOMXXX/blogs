---
import { COLUMN_LABELS, COLUMN_TAG_COLOR } from '../../content/config';

interface Props {
  slug: string;
  title: string;
  description: string;
  column: keyof typeof COLUMN_LABELS;
  readingTimeStr: string;
}

const { slug, title, description, column, readingTimeStr } = Astro.props;
const tagColor = COLUMN_TAG_COLOR[column];
---

<a class="card" href={`/posts/${slug}`} style={`--card-accent: ${tagColor}`}>
  <span class="tag" style={`color: ${tagColor}`}>{COLUMN_LABELS[column]}</span>
  <h3>{title}</h3>
  <p>{description}</p>
  <div class="meta">{readingTimeStr}</div>
</a>

<style>
  .card {
    display: block;
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-left: 2px solid var(--card-accent, var(--color-accent-purple));
    border-radius: 8px;
    padding: 16px 18px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .card:hover { transform: translateY(-2px); border-color: var(--color-border-strong); }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 6px;
  }
  .card h3 {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-text-primary);
    margin: 4px 0 8px;
    line-height: 1.3;
    font-weight: 600;
  }
  .card p {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 0 0 8px;
    line-height: 1.5;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-faint);
  }
</style>

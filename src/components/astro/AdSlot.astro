---
interface Props {
  position: string;
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
  minHeight?: number;
}

const { position, format = 'auto', minHeight = 90 } = Astro.props;
---

<div
  class="ad-slot"
  data-ad-slot={position}
  data-ad-format={format}
  style={`min-height: ${minHeight}px`}
>
</div>

<style>
  .ad-slot {
    margin: 24px 0;
  }
</style>

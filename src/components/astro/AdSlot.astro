---
interface Props {
  position: string;
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
}

const { position, format = 'auto' } = Astro.props;
---

<div class="ad-slot">
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-7299456929245815"
    data-ad-slot="7743694031"
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    (adsbygoogle = window.adsbygoogle || []).push({});
  </script>
</div>

<style>
  .ad-slot {
    margin: 16px 0;
  }
  .ad-slot:empty,
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

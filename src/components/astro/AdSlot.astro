---
interface Props {
  position: string;
  slot: string;
  format?: 'auto' | 'horizontal' | 'vertical' | 'rectangle';
}

const { position, slot, format = 'auto' } = Astro.props;
---

<div class="ad-slot" data-position={position}>
  <ins
    class="adsbygoogle"
    style="display:block"
    data-ad-client="ca-pub-7299456929245815"
    data-ad-slot={slot}
    data-ad-format={format}
    data-full-width-responsive="true"
  ></ins>
  <script is:inline>
    try { (adsbygoogle = window.adsbygoogle || []).push({}); } catch(e) {}
  </script>
</div>

<style>
  .ad-slot {
    margin: 16px 0;
  }
  .ad-slot:empty,
  .ad-slot:has(ins[data-ad-status="unfilled"]) {
    display: none;
  }
</style>

---
import { COLUMN_LABELS, COLUMN_TAG_COLOR } from '../../content/config';

interface PickEntry {
  slug: string;
  title: string;
  column: keyof typeof COLUMN_LABELS;
  readingTimeStr: string;
}

interface Props {
  picks: PickEntry[];
}

const { picks } = Astro.props;
---

<section class="picks">
  <div class="section-h">
    <span class="file">editor-picks.json</span>
    <span class="arrow">›</span>
    <span>Editor's Picks</span>
  </div>
  <div class="grid">
    {
      picks.map((p) => (
        <a class="card" href={`/posts/${p.slug}`} style={`--card-accent: ${COLUMN_TAG_COLOR[p.column]}`}>
          <span class="tag" style={`color: ${COLUMN_TAG_COLOR[p.column]}`}>
            {COLUMN_LABELS[p.column]}
          </span>
          <h4>{p.title}</h4>
          <div class="meta">{p.readingTimeStr}</div>
        </a>
      ))
    }
  </div>
</section>

<style>
  .picks { margin-bottom: 28px; }
  .section-h {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-accent-green);
    margin-bottom: 12px;
    display: flex;
    gap: 6px;
    align-items: center;
  }
  .section-h .file { color: var(--color-accent-amber); }
  .section-h .arrow { color: var(--color-text-faint); }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }
  .card {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-left: 2px solid var(--card-accent, var(--color-accent-purple));
    border-radius: 8px;
    padding: 14px 16px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.15s, border-color 0.15s;
  }
  .card:hover {
    transform: translateY(-2px);
    border-color: var(--color-border-strong);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.5px;
    text-transform: uppercase;
    margin-bottom: 6px;
    display: inline-block;
  }
  .card h4 {
    font-family: var(--font-sans);
    font-size: 15px;
    color: var(--color-text-primary);
    margin: 4px 0 6px;
    line-height: 1.3;
    font-weight: 600;
  }
  .meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-faint);
  }
  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>

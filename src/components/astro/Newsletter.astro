---
---

<section class="newsletter">
  <h4>// subscribe to Frontier Brief</h4>
  <p>1 signal per week. AI infrastructure, agents, RAG — distilled. No spam, ever.</p>
  <form
    class="form"
    action="https://yomxxx.substack.com/subscribe"
    method="GET"
    target="_blank"
  >
    <input
      class="input"
      type="email"
      name="email"
      autocomplete="email"
      placeholder="your@email.com"
      aria-label="Email address"
      required
    />
    <button class="btn" type="submit">SUBSCRIBE →</button>
  </form>
  <p class="note">
    Powered by <a href="https://yomxxx.substack.com" target="_blank" rel="noopener noreferrer">Substack</a>
    · See <a href="/newsletter">all tiers</a>
  </p>
</section>

<style>
  .newsletter {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 10px;
    padding: 24px 28px;
    text-align: center;
    margin-top: 28px;
  }
  .newsletter h4 {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--color-accent-green);
    margin: 0 0 4px;
    font-weight: 600;
  }
  .newsletter p {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 0 0 14px;
  }
  .form {
    display: flex;
    gap: 6px;
    max-width: 420px;
    margin: 0 auto;
  }
  .input {
    flex: 1;
    background: var(--color-bg-primary);
    border: 1px solid var(--color-border-strong);
    border-radius: 5px;
    padding: 8px 12px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-primary);
  }
  .input:focus {
    outline: none;
    border-color: var(--color-accent-green);
  }
  .input::placeholder { color: var(--color-text-faint); }
  .btn {
    background: var(--color-accent-green);
    color: var(--color-bg-primary);
    border: none;
    border-radius: 5px;
    padding: 8px 18px;
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    letter-spacing: 0.5px;
  }
  .btn:hover { opacity: 0.9; }
  .note {
    font-size: 10px;
    color: var(--color-text-faint);
    margin: 12px 0 0;
  }
  .note a {
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .note a:hover { color: var(--color-accent-green); }
</style>

---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/astro/Header.astro';
import Footer from '../components/astro/Footer.astro';
const lastUpdated = '2026-05-09';
---

<BaseLayout
  title="Privacy Policy · Nexus.AI"
  description="Privacy policy for Nexus.AI — what data we collect, how we use it, and your rights."
  noindex={false}
>
  <Header />
  <main class="container">
    <div class="breadcrumb">
      <span>nexus</span> / <span class="cur">privacy</span>
    </div>
    <h1><span class="prefix">▸</span>Privacy Policy</h1>
    <p class="lead">Last updated: {lastUpdated}</p>

    <div class="prose">
      <h2>What we collect</h2>
      <p>
        Nexus.AI is a static website. We do not require accounts, do not run a database of
        users, and do not store personal data on our servers. The following limited data is
        collected:
      </p>
      <ul>
        <li>
          <strong>Aggregate traffic stats</strong> via Cloudflare Web Analytics — these are
          anonymous and use no cookies.
        </li>
        <li>
          <strong>Newsletter signups</strong> (when implemented in Plan 4) — only the email
          address you submit, processed by Buttondown. You can unsubscribe at any time.
        </li>
        <li>
          <strong>Comments</strong> via Giscus — these are stored on GitHub Discussions under
          your GitHub identity. We see only what GitHub exposes publicly.
        </li>
        <li>
          <strong>Advertising data</strong> — when Google AdSense is enabled (Plan 4), Google
          may set cookies to serve relevant ads. See
          <a href="https://policies.google.com/technologies/ads" target="_blank" rel="noopener noreferrer">
            Google's ad policies
          </a>
          for details.
        </li>
      </ul>

      <h2>Cookies</h2>
      <p>
        We do not set cookies directly. Third-party cookies may be set by Google AdSense
        (ad personalization) or Giscus (login state). You can opt out of personalized ads at
        <a href="https://adssettings.google.com" target="_blank" rel="noopener noreferrer">
          Google's Ad Settings
        </a>.
      </p>

      <h2>GDPR / CCPA</h2>
      <p>
        EU and California residents have the right to access, correct, or delete personal
        data we hold about them. Since we hold almost none, this typically means
        unsubscribing from the newsletter or asking us to delete your subscription record.
        Email us at the address on the <a href="/contact">contact</a> page.
      </p>

      <h2>Children's privacy</h2>
      <p>
        Nexus.AI is not directed at children under 13 and we do not knowingly collect data
        from them.
      </p>

      <h2>Changes</h2>
      <p>
        We may update this policy as the site evolves. The "Last updated" date above will
        reflect when changes were made.
      </p>
    </div>
  </main>
  <Footer />
</BaseLayout>

<style>
  .container { max-width: 720px; margin: 0 auto; padding: 28px 24px 40px; }
  .breadcrumb { font-family: var(--font-mono); font-size: 11px; color: var(--color-text-faint); margin-bottom: 6px; }
  .breadcrumb span { color: var(--color-accent-green); }
  .breadcrumb .cur { color: var(--color-accent-amber); }
  h1 {
    font-family: var(--font-mono);
    font-size: 26px;
    color: var(--color-text-primary);
    margin: 0 0 8px;
    font-weight: 700;
  }
  h1 .prefix { color: var(--color-accent-green); margin-right: 6px; }
  .lead {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text-faint);
    margin: 0 0 24px;
  }
</style>
